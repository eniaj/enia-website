---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Jason Enia - About"
  description="Biography and education of Jason Enia, Associate Dean and Professor of Political Science."
>
  <article class="max-w-4xl mx-auto py-12 md:py-24 px-4">
    <header class="mb-12 md:mb-16">
      <h1
        class="text-5xl md:text-7xl font-serif font-bold tracking-tight text-charcoal dark:text-softcream mb-3"
      >
        Jason Enia
      </h1>
      <p
        class="text-xl md:text-2xl text-charcoal/80 dark:text-softcream/80 font-light max-w-2xl leading-tight"
      >
        Associate Dean & Professor of Political Science<br />
        <span
          class="text-base md:text-lg italic text-charcoal/60 dark:text-softcream/60 block mt-1"
          >Sam Houston State University</span
        >
      </p>
      <div class="w-16 h-px bg-rust-500/60 mt-8"></div>
    </header>

    <div class="space-y-16">
      <!-- Biography Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
        <div class="col-span-1 md:col-span-4">
          <h2
            class="text-sm font-bold uppercase tracking-widest text-charcoal/40 dark:text-softcream/40 mb-4 md:sticky md:top-32"
          >
            Biography
          </h2>
        </div>
        <div class="col-span-1 md:col-span-8">
          <div
            class="text-lg text-charcoal/80 dark:text-softcream/80 font-light leading-normal space-y-6"
          >
            <p>
              I am a political economist and Professor of Political Science at
              Sam Houston State University (SHSU), where I serve as the
              Associate Dean of Student Success in the College of Humanities and
              Social Sciences. Previously, I chaired the Political Science
              Department and founded the university's Center for the Study of
              Disasters & Emergency Management.
            </p>
            <p>
              My research is driven by a core premise: understanding complex
              political behavior requires exploring the underlying incentives. I
              apply this framework to the politics of nuclear weapons, natural
              disasters, and international cooperation. Whether in the
              classroom, in academic leadership, or through my research, my goal
              is to explain and understand how politics actually works.
            </p>
          </div>
        </div>
      </section>

      <hr class="border-t border-charcoal/10 dark:border-softcream/10" />

      <!-- Education Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
        <div class="col-span-1 md:col-span-4">
          <h2
            class="text-sm font-bold uppercase tracking-widest text-charcoal/40 dark:text-softcream/40 mb-4 md:sticky md:top-32"
          >
            Education
          </h2>
        </div>
        <div class="col-span-1 md:col-span-8">
          <ul class="space-y-10 list-none pl-0 m-0">
            <li class="relative">
              <span
                class="block text-xs font-medium tracking-widest uppercase text-rust-600 dark:text-rust-500 mb-1"
                >Doctor of Philosophy</span
              >
              <strong
                class="font-serif text-2xl text-charcoal dark:text-softcream block mb-1"
                >Politics & International Relations</strong
              >
              <span
                class="text-charcoal/70 dark:text-softcream/70 font-light italic"
                >University of Southern California</span
              >
            </li>

            <li class="relative">
              <span
                class="block text-xs font-medium tracking-widest uppercase text-rust-600 dark:text-rust-500 mb-1"
                >Master of Arts</span
              >
              <strong
                class="font-serif text-2xl text-charcoal dark:text-softcream block mb-1"
                >International Political Economy & Development</strong
              >
              <span
                class="text-charcoal/70 dark:text-softcream/70 font-light italic"
                >Fordham University</span
              >
            </li>

            <li class="relative">
              <span
                class="block text-xs font-medium tracking-widest uppercase text-rust-600 dark:text-rust-500 mb-1"
                >Bachelor of Arts</span
              >
              <strong
                class="font-serif text-2xl text-charcoal dark:text-softcream block mb-1"
                >Economics & Political Science</strong
              >
              <span
                class="text-charcoal/70 dark:text-softcream/70 font-light italic"
                >University of Dayton</span
              >
            </li>
          </ul>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
