---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Jason Enia - Contact"
  description="Get in touch with Jason Enia, Sam Houston State University."
>
  <article class="max-w-4xl mx-auto py-12 md:py-24 px-4">
    <header class="mb-12 md:mb-16">
      <h1
        class="text-5xl md:text-7xl font-serif font-bold tracking-tight text-charcoal dark:text-softcream mb-3"
      >
        Get in Touch
      </h1>
      <p
        class="text-xl md:text-2xl text-charcoal/80 dark:text-softcream/80 font-normal max-w-2xl leading-tight"
      >
        Academic inquiries, speaking engagements, or consulting.
      </p>
      <div class="w-16 h-px bg-rust-500/60 mt-8"></div>
    </header>

    <div class="space-y-16">
      <!-- Direct Contact Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
        <div class="col-span-1 md:col-span-4">
          <h2
            class="text-sm font-bold uppercase tracking-widest text-charcoal/40 dark:text-softcream/40 mb-4 md:sticky md:top-32"
          >
            Direct Contact
          </h2>
        </div>
        <div class="col-span-1 md:col-span-8 space-y-16">
          <article class="group relative">
            <h3
              class="text-3xl font-serif font-semibold text-charcoal dark:text-softcream mb-4"
            >
              Email
            </h3>
            <div
              class="text-base text-charcoal/60 dark:text-softcream/60 font-light leading-normal prose dark:prose-invert mb-6"
            >
              <p>
                &#106;&#97;&#115;&#111;&#110;&#46;&#101;&#110;&#105;&#97;&#64;&#115;&#104;&#115;&#117;&#46;&#101;&#100;&#117;
              </p>
            </div>

            <div
              class="flex items-center justify-end border-t border-charcoal/5 dark:border-softcream/5 pt-4"
            >
              <a
                href="mailto:jason.enia@shsu.edu"
                class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-charcoal/50 dark:text-softcream/50 hover:text-charcoal dark:hover:text-softcream transition-colors"
              >
                Send Email <span class="ml-2">→</span>
              </a>
            </div>
          </article>

          <article class="group relative">
            <h3
              class="text-3xl font-serif font-semibold text-charcoal dark:text-softcream mb-4"
            >
              Office
            </h3>
            <div
              class="text-base text-charcoal/60 dark:text-softcream/60 font-light leading-normal prose dark:prose-invert mb-6"
            >
              <p>
                CHSS Dean's Office<br />Sam Houston State University<br
                />Huntsville, TX 77341
              </p>
            </div>

            <div
              class="flex items-center justify-end border-t border-charcoal/5 dark:border-softcream/5 pt-4"
            >
              <a
                href="https://maps.app.goo.gl/Q8ojW4SL1NoNAAam8"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-charcoal/50 dark:text-softcream/50 hover:text-charcoal dark:hover:text-softcream transition-colors"
              >
                View Map <span class="ml-2">→</span>
              </a>
            </div>
          </article>
        </div>
      </section>

      <hr class="border-t border-charcoal/10 dark:border-softcream/10" />

      <!-- Professional Profiles Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
        <div class="col-span-1 md:col-span-4">
          <h2
            class="text-sm font-bold uppercase tracking-widest text-charcoal/40 dark:text-softcream/40 mb-4 md:sticky md:top-32"
          >
            Professional Profiles
          </h2>
        </div>
        <div class="col-span-1 md:col-span-8 space-y-16">
          <article class="group relative">
            <h3
              class="text-3xl font-serif font-semibold text-charcoal dark:text-softcream mb-4"
            >
              LinkedIn
            </h3>
            <div
              class="text-base text-charcoal/60 dark:text-softcream/60 font-light leading-normal prose dark:prose-invert mb-6"
            >
              <p>Network and follow professional updates.</p>
            </div>

            <div
              class="flex items-center justify-end border-t border-charcoal/5 dark:border-softcream/5 pt-4"
            >
              <a
                href="https://www.linkedin.com/in/jasonenia/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-charcoal/50 dark:text-softcream/50 hover:text-charcoal dark:hover:text-softcream transition-colors"
              >
                Connect <span class="ml-2">→</span>
              </a>
            </div>
          </article>

          <article class="group relative">
            <h3
              class="text-3xl font-serif font-semibold text-charcoal dark:text-softcream mb-4"
            >
              Google Scholar
            </h3>
            <div
              class="text-base text-charcoal/60 dark:text-softcream/60 font-light leading-normal prose dark:prose-invert mb-6"
            >
              <p>View complete citation history and publications.</p>
            </div>

            <div
              class="flex items-center justify-end border-t border-charcoal/5 dark:border-softcream/5 pt-4"
            >
              <a
                href="https://scholar.google.com/citations?user=IpgtHIgAAAAJ&hl=en"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-charcoal/50 dark:text-softcream/50 hover:text-charcoal dark:hover:text-softcream transition-colors"
              >
                View Citations <span class="ml-2">→</span>
              </a>
            </div>
          </article>
        </div>
      </section>
    </div>
  </article>
</BaseLayout>
